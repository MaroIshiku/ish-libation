# Libiku runtime
TZ=Europe/Berlin
PORT=3000
NODE_ENV=production

# First-run setup
# Prefer Docker secrets in compose:
#   ISHIKU_SETUP_SECRET_FILE=/run/secrets/ishiku_setup_secret
# Use ISHIKU_SETUP_SECRET only for simple local deployments.
ISHIKU_SETUP_SECRET_FILE=/run/secrets/ishiku_setup_secret
# ISHIKU_SETUP_SECRET=change-this-only-for-local-tests

# Libiku admin/session state
LIBIKU_AUTH_FILE=/config/LibikuAuth.json
LIBIKU_SESSION_TTL_SECONDS=604800

# Libation paths
LIBATION_CLI=/libation/LibationCli
LIBATION_FILES_DIR=/config
LIBATION_CONFIG_DIR=/config
LIBATION_DB_DIR=/db
LIBATION_DB_FILE=
LIBATION_BOOKS_DIR=/data

# Networking diagnostics
PUBLIC_IP_URL=https://api.ipify.org?format=json
PUBLIC_IP_INTERVAL_SECONDS=300
